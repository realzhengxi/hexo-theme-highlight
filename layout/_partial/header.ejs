<%# Header - Site Title & Navigation %>
<header class="site-header">
  <% if (config.title) { %>
    <h1 class="site-title">
      <a href="<%= url_for('/') %>"><%= config.title %></a>
    </h1>
  <% } %>
  
  <% if (theme.site_subtitle || config.subtitle) { %>
    <p class="site-subtitle"><%= theme.site_subtitle || config.subtitle %></p>
  <% } %>

  <nav class="site-nav">
    <a class="nav-link" href="<%= url_for('/') %>">Home</a>
    <a class="nav-link" href="<%= url_for('/archives/') %>">Archives</a>
    <button class="search-btn nav-link" id="search-btn" aria-label="Search">
      🔍 Search
    </button>
  </nav>
</header>
