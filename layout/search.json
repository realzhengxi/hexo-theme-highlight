<%# Search JSON - 供前端搜索使用 %>
[
<% var posts = site.posts.sort('date', -1); %>
<% posts.forEach(function(post, i) { %>
{
  "title": "<%= post.title.replace(/"/g, '\\"') %>",
  "url": "<%= url_for(post.path) %>",
  "text": "<%= strip_html(post.content).replace(/"/g, '\\"').replace(/\s+/g, ' ').trim().substring(0, 300) %>"
}<%- (i < posts.length - 1 ? ',' : '') %>
<% }) %>
]
